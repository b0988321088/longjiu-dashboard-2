def load_snapshot() -> dict:

    cwd = Path(__file__).parent

    print("[DEBUG] cwd:", cwd)

    print("[DEBUG] glob files:", sorted(list(cwd.glob("framework_snapshot_*.json")) + list(cwd.glob("framework_snapshot_*_final.json")), reverse=True))

    for f in sorted(list(cwd.glob("framework_snapshot_*.json")) + list(cwd.glob("framework_snapshot_*_final.json")), reverse=True):

        try:

            data = json.loads(f.read_text(encoding="utf-8"))

            print("[DEBUG] loaded file keys:", list(data.keys())[:5])

            if "snapshot" in data:

                print("[DEBUG] using snapshot key")

                return data["snapshot"]

            if "pages" in data:

                print("[DEBUG] using pages key")

                return data

        except Exception as e:

            print("[DEBUG] load error:", e)

            continue

    print("[DEBUG] returning empty dict")

    return {}



