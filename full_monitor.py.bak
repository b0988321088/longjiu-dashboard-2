def get_dividend_alerts():
    """T-4 / T-2 除息預警"""
    from datetime import datetime, timedelta
    alerts = []
    today = datetime.today().date()
    for item in DIVIDEND_LIGHT_LIST:
        ex = item.get('ex_date')
        if not ex:
            continue
        ex_date = datetime.strptime(ex, '%Y-%m-%d').date()
        delta = (ex_date - today).days
        if item['type'] == 'flash' and 0 <= delta <= 2:
            alerts.append(f"⚡ {item['code']} {item['name']} 除息前 T-{delta}，啟動稅務/帳戶排程")
        elif item['type'] == 'general' and 0 <= delta <= 4:
            alerts.append(f"🔔 {item['code']} {item['name']} 除息前 T-{delta}，確認配息帳戶/扣款")
    return alerts if alerts else ["✅ 除息：近期無需預警"]


def build_calendar_events_for_dividends():
    """將除息預警轉為行事曆事件摘要"""
    from datetime import datetime, timedelta
    events = []
    today = datetime.today().date()
    for item in DIVIDEND_LIGHT_LIST:
        ex = item.get('ex_date')
        if not ex:
            continue
        ex_date = datetime.strptime(ex, '%Y-%m-%d').date()
        if item['type'] == 'flash':
            alert_date = ex_date - timedelta(days=2)
            events.append(f"🗓 T-2 {alert_date}｜{item['code']} {item['name']} 閃電調度預警")
        else:
            alert_date = ex_date - timedelta(days=4)
            events.append(f"🗓 T-4 {alert_date}｜{item['code']} {item['name']} 配息帳戶預警")
    return events


def fetch_market_news():
    """從 Google News RSS 取得最新市場動態，融入巴菲特視角"""
    import requests
    from xml.etree import ElementTree as ET
    news_items = []
    try:
        headers = {'User-Agent': 'Mozilla/5.0'}
        rss_sources = [
            ("https://news.google.com/rss/search?q=0050+00878+%E5%8F%B0%E8%82%A1&hl=zh-TW&gl=TW&ceid=TW:zh-Hant", "📰", 4),
            ("https://news.google.com/rss/search?q=US+stock+market+SaaS&hl=en-US&gl=US&ceid=US:en", "🌎", 3),
        ]
        for url, prefix, limit in rss_sources:
            try:
                resp = requests.get(url, headers=headers, timeout=10)
                if resp.status_code == 200:
                    root = ET.fromstring(resp.content)
                    for item in root.findall('.//item')[:limit]:
                        title = item.find('title')
                        if title is not None and title.text:
                            news_items.append(f"{prefix} {title.text}")
            except Exception:
                continue
    except Exception as e:
        news_items.append(f"[WARN] 新聞抓取失敗：{e}")
    # Fallback: 靜態 headline
    if not news_items:
        news_items = ["📰 市場情報：台股盤後整理，美股科技股漲跌互見",
                      "🌎 美股：微軟上漲，硬體板塊回調"]
    return news_items


def generate_daily_report():
    """二元架構日報：動產水位 + 不動產現金流 + 本週戰略導航 + 巴菲特檢查"""
    tw_ratio, us_ratio, cash_ratio = get_allocation_ratios()
    runway = get_runway()
    liquid = get_total_liquid_cash()
    insurance_total = get_total_insurance()
    now = datetime.now()
    now_str = now.strftime('%Y-%m-%d %H:%M:%S')

    # 動產 module
    gain_loss = calculate_daily_gain_loss()
    severe, high, normal = get_premium_alert_groups()

    # 退休後月度盈餘（完整明細）
    retirement_income = 80000 + 80100  # 160,100
    retirement_expense = MONTHLY_MORTGAGE + MONTHLY_CREDIT_CARD + MONTHLY_LIVING_EXPENSE + MONTHLY_RENT_SHA_LU
    monthly_surplus = 160100 - retirement_expense

    report = (
        f"📊 *龍九資產管理系統 2.0 日報*\n"
        f"🕒 報告時間：{now_str}\n"
        f"💰 可動用現金：{liquid:,.0f} TWD\n"
        f"🛡️ 保單現值：{insurance_total:,.0f} TWD\n\n"
        f"=== 動產水位 ===\n"
    )
    for r in gain_loss:
        report += (
            f"{r['code']}：現值 {r['current_price']:.2f} | "
            f"報酬 {r['return_pct']:+.2f}% | {r['premium_level']}\n"
        )
    if severe:
        report += f"\n🚨 嚴重溢價：{', '.join([r['code'] for r in severe])}\n"
    if high:
        report += f"⚠️ 溢價偏高：{', '.join([r['code'] for r in high])}\n"

    report += (
        f"\n=== 不動產現金流 ===\n"
        f"大義街月租金：47,100/月（店面24K + 2-3F 23.1K）\n"
        f"洲際W月租金：33,000/月\n"
        f"每月租金合計：80,100/月\n"
        f"每月房貸支出：{MONTHLY_MORTGAGE:,.0f}/月\n"
        f"退休後月盈餘：{monthly_surplus:,.0f}/月\n\n"
        f"📈 配置比例：台股 {tw_ratio:.1%} / 美股 {us_ratio:.1%} / 現金防禦 {cash_ratio:.1%}\n"
        f"⏳ 流動性 Runway：{runway:.1f} 個月\n"
    )

    # 近期節點預警
    report += f"\n🔔 近期節點：7/10 大義街轉貸｜10月 洲際W轉貸\n"

    # 市場情報 Light List
    news_report = fetch_market_news()
    report += f"\n📰 *市場情報導航*\n"
    for line in news_report:
        report += f"{line}\n"

    # 本週戰略導航
    report += f"\n🗓️ *本週戰略導航*\n"
    today = now.date()
    # 動態計算剩餘天數
    def days_left(target_str):
        target = datetime.strptime(target_str, '%Y-%m-%d').date()
        return (target - today).days

    report += f"【P0】07/10 大義街轉貸撥款（剩餘 {days_left('2026-07-10')} 天）\n"
    report += f"【行事曆】07/11 台南行程出發（剩餘 {days_left('2026-07-11')} 天）\n"
    report += f"【行事曆】07/12 台南演唱會（剩餘 {days_left('2026-07-12')} 天）\n"
    report += f"【行事曆】07/14 水保竣工會勘（峨眉變電所，剩餘 {days_left('2026-07-14')} 天）\n"
    report += f"【行事宜】07/17 段部上課：工安AI（剩餘 9 天）\n"
    report += f"【行事宜】08/03 段部體檢（剩餘 {days_left('2026-08-03')} 天）\n"
    report += f"【旅行】10/23 胡志明市自由行（剩餘 {days_left('2026-10-23')} 天）\n"

    # 租金倒數
    report += f"\n⏳ *租金倒數*\n"
    report += f"距離 07/20 洲際W租金入帳：剩餘 {days_left('2026-07-20')} 天\n"
    report += f"距離 07/01 大義街店面租金：剩餘 {days_left('2026-08-01')} 天\n"
    report += f"距離 07/20 大義街2-3F租金：剩餘 {days_left('2026-07-20')} 天\n"

    report += f"\n✍️ *裁決簽核*：動產若出現嚴重溢價，請回覆『減碼』；合理估值則『持有』。\n\n"
    report += get_buffett_check()
    return report

def check_credit_card_alerts():
    """檢查是否為卡費扣款前 3 天"""
    today = datetime.now().date()
    alerts = []
    for card in CREDIT_CARDS:
        if not card['due']:
            continue
        try:
            due = datetime.strptime(card['due'], '%Y-%m-%d').date()
        except ValueError:
            continue
        days_left = (due - today).days
        if 0 <= days_left <= 3:
            alerts.append(f"💳 {card['bank']} 卡費繳款截止日：{card['due']}（剩 {days_left} 天，最低 {card['min_pay']:,}）")
    return "\n".join(alerts) if alerts else ""

# ==========================================================================
# 主監控循環（每日檢查）
# ==========================================================================
def run_dragon_nine_monitor():
    print("=" * 60)
    print("【龍九資產管理系統 2.0】完全體通電成功！")
    print(f"啟動時間: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print("實時指揮監測引擎已上線，每日檢查資產配置與卡費預警。")
    print("=" * 60)
    send_telegram_message("🟢 龍九資產管理系統 2.0 已啟動，開始執行每日監控。")
    last_report_date = None
    while True:
        now = datetime.now()
        today = now.date()
        # 每日 09:00 推送日報
        if last_report_date != today and now.hour == 9 and now.minute < 5:
            report = generate_daily_report()
            print(report)
            send_telegram_message(report)
            last_report_date = today
        # 每日檢查卡費預警一次
        cc_alert = check_credit_card_alerts()
        if cc_alert:
            print(cc_alert)
            send_telegram_message(cc_alert)
        # 每天檢查一次，不再每小時
        time.sleep(86400)  # 每 24 小時醒來檢查一次

if __name__ == "__main__":
    run_dragon_nine_monitor()
