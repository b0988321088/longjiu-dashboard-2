{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "龍九控股 Snapshot schema v2",
  "description": "snapshot 規範 v2：對齊 Company_Ledger.md 真值，並兼容 dashboard.py base64 載入與 pages 包裝。",
  "type": "object",
  "required": ["generated_at", "version", "date", "pages"],
  "additionalProperties": true,
  "properties": {
    "generated_at": {
      "type": "string",
      "description": "ISO8601 快照產生時間，TZ aware。"
    },
    "version": {
      "type": "string",
      "description": "資料規格版本，例如 v5.0.9-flagship-fix。"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "YYYY-MM-DD，台灣時間日期標籤。"
    },
    "snapshot": {
      "type": "object",
      "description": "相容舊版頂層包裝；載入器會回退/扁平化。",
      "properties": {
        "pages": {
          "type": "object"
        }
      }
    },
    "total_assets": {
      "type": ["integer", "number"],
      "description": "總資產 TWD，對齊 Company_Ledger。"
    },
    "total_liabilities": {
      "type": ["integer", "number"],
      "description": "總負債 TWD。"
    },
    "net_worth": {
      "type": ["integer", "number"],
      "description": "淨值 = 總資產 - 總負債。"
    },
    "debt_ratio": {
      "type": "string",
      "description": "負債比字串，例如 '48.3%'。"
    },
    "monthly_income": {
      "type": ["integer", "number"]
    },
    "monthly_expense": {
      "type": ["integer", "number"]
    },
    "working_surplus": {
      "type": ["integer", "number"],
      "description": "工作期月盈餘。"
    },
    "retirement_surplus": {
      "type": ["integer", "number"],
      "description": "退休後月盈餘。"
    },
    "securities_total_market_value": {
      "type": ["integer", "number"]
    },
    "insurance_monthly_dividend": {
      "type": ["integer", "number"]
    },
    "relay_status": {
      "type": "object",
      "description": "配息接力站狀態快照，落於頂層與 page3 兩處皆可。",
      "properties": {
        "first_leg": {
          "type": "object",
          "required": ["done", "date", "from", "to"],
          "properties": {
            "done": { "type": "boolean" },
            "date": { "type": "string" },
            "from": { "type": "string" },
            "to": { "type": "string" },
            "policy": { "type": "string" }
          }
        },
        "second_leg": {
          "type": "object",
          "required": ["done", "date", "from", "to"],
          "properties": {
            "done": { "type": "boolean" },
            "date": { "type": "string" },
            "from": { "type": "string" },
            "to": { "type": "string" },
            "policy": { "type": "string" }
          }
        },
        "third_leg": {
          "type": "object",
          "required": ["done", "date", "from", "to"],
          "properties": {
            "done": { "type": "boolean" },
            "date": { "type": "string" },
            "from": { "type": "string" },
            "to": { "type": "string" },
            "policy": { "type": "string" }
          }
        },
        "fourth_leg": {
          "type": "object",
          "required": ["done", "planned", "from", "to"],
          "properties": {
            "done": { "type": "boolean" },
            "planned": { "type": "string" },
            "from": { "type": "string" },
            "to": { "type": "string" }
          }
        }
      }
    },
    "page1": {
      "$ref": "#/$defs/page1"
    },
    "page1_wealth_baseline": {
      "$ref": "#/$defs/page1"
    },
    "page2_allocation": {
      "$ref": "#/$defs/page2"
    },
    "page2_strategic_risk": {
      "$ref": "#/$defs/page2"
    },
    "page3_insurance_relay": {
      "$ref": "#/$defs/page3"
    },
    "page3_allocation": {
      "$ref": "#/$defs/page3"
    },
    "page4_liquidity": {
      "$ref": "#/$defs/page4"
    },
    "page4_liquidity_banking": {
      "$ref": "#/$defs/page4"
    },
    "page5_actions": {
      "$ref": "#/$defs/page5"
    },
    "page5_tactical_ops": {
      "$ref": "#/$defs/page5"
    },
    "page5_battle": {
      "$ref": "#/$defs/page5"
    }
  },
  "$defs": {
    "cashFlow": {
      "type": "object",
      "description": "actual_cash_flow，收入與支出字典。",
      "properties": {
        "income": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "收入明細：項目名稱 -> TWD"
        },
        "expense": {
          "type": "object",
          "additionalProperties": { "type": "number" },
          "description": "支出明細：項目名稱 -> TWD"
        }
      }
    },
    "page1": {
      "type": "object",
      "description": "page1｜財富生命線",
      "required": ["actual_cash_flow", "total_income", "total_expense", "working_surplus", "retirement_surplus"],
      "properties": {
        "actual_cash_flow": {
          "$ref": "#/$defs/cashFlow"
        },
        "income": {
          "type": "object",
          "description": "相容別名， dashboard.py 可回退使用。",
          "additionalProperties": { "type": "number" }
        },
        "expense": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "total_income": {
          "type": "number",
          "description": "本月確認收入合計。"
        },
        "total_expense": {
          "type": "number",
          "description": "本月支出合計。"
        },
        "working_surplus": {
          "type": "number"
        },
        "retirement_surplus": {
          "type": "number"
        },
        "runway_months": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" }
          ],
          "description": "若不提供，dashbaord 會以 accounts / expense 計算回退值。"
        },
        "debt_ratio": {
          "type": "string",
          "description": "優先頂層 debt_ratio，此欄為同層越多重覆或字串。"
        },
        "context": {
          "type": "array",
          "items": { "type": "string" },
          "description": "市場脈動清單。"
        }
      }
    },
    "allocationItem": {
      "type": "object",
      "required": ["標的", "市值", "佔比", "缺口"],
      "additionalProperties": true,
      "properties": {
        "標的": { "type": "string" },
        "市值": { "type": "number" },
        "佔比": { "type": "string" },
        "缺口": { "type": "string" }
      }
    },
    "page2": {
      "oneOf": [
        { "$ref": "#/$defs/page2_normalized" },
        { "$ref": "#/$defs/page2_legacy_flat" }
      ],
      "description": "page2｜戰略異常中心。支援兩種輸入：dashboard.py 會補齊 normalized 欄位。"
    },
    "page2_normalized": {
      "type": "object",
      "required": ["allocation_analysis", "buffett_decision", "gemini_analysis"],
      "properties": {
        "allocation_analysis": {
          "$ref": "#/$defs/allocationAnalysis"
        },
        "red_zone": {
          "type": "array",
          "items": { "$ref": "#/$defs/redZoneRecord" }
        },
        "holdings_composition": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/holdingClass" }
        },
        "buffett_decision": {
          "$ref": "#/$defs/buffettDecision"
        },
        "concentration": {
          "type": "array",
          "items": { "$ref": "#/$defs/concentrationRecord" }
        },
        "industry_exposure": {
          "type": "object",
          "additionalProperties": true
        },
        "gemini_analysis": {
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ]
        },
        "gemini_suggestion": {
          "oneOf": [
            { "type": "string" },
            { "type": "object" }
          ],
          "description": "自動別名對應到 gemini_analysis。"
        },
        "leverage": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "buffett_view": {
          "$ref": "#/$defs/buffettDecision",
          "description": "自動別名對應到 buffett_decision。"
        },
        "buffett_list": {
          "type": "array",
          "items": { "type": "string" },
          "description": "自動別名，護城河清單。"
        }
      }
    },
    "page2_legacy_flat": {
      "type": "object",
      "description": "落於 pages.page2_strategic_risk 的扁平表格快照。",
      "properties": {
        "系統目標": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "台股市值型成長": {
          "$ref": "#/$defs/allocationItem"
        },
        "美股市值型成長": {
          "$ref": "#/$defs/allocationItem"
        },
        "防守型配息": {
          "$ref": "#/$defs/allocationItem"
        },
        "債券及現金": {
          "$ref": "#/$defs/allocationItem"
        },
        "結論": { "type": "string" },
        "industry_exposure": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/industryExposureItem" }
        },
        "buffett_view": {
          "properties": {
            "能力圈": { "type": "string" },
            "持股": { "type": "string" },
            "建議": { "type": "string" }
          }
        }
      },
      "additionalProperties": true
    },
    "allocationAnalysis": {
      "type": "object",
      "required": ["current", "target", "variance", "status"],
      "properties": {
        "current": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "target": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "number" },
              { "type": "string", "pattern": "^\\d+%?$" }
            ]
          }
        },
        "variance": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "status": { "type": "string" }
      }
    },
    "redZoneRecord": {
      "type": "object",
      "required": ["ticker", "name", "return_pct", "status", "level"],
      "additionalProperties": true,
      "properties": {
        "ticker": { "type": "string" },
        "name": { "type": "string" },
        "return_pct": { "type": "number" },
        "premium_pct": { "type": "number" },
        "status": { "type": "string" },
        "level": { "type": "string" }
      }
    },
    "holdingClass": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "string" }
        },
        "total_value": { "type": "number" },
        "allocation_pct": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "buffettDecision": {
      "type": "object",
      "properties": {
        "scope": { "type": "string" },
        "circle_of_competence": { "type": "string" },
        "moat": { "type": ["string", "array", "object"] },
        "holdings": { "type": "string" },
        "margin_of_safety": { "type": ["string", "array", "object"] },
        "insurance_assets": { "type": "string" },
        "action": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "concentrationRecord": {
      "oneOf": [
        {
          "type": "object",
          "required": ["industry", "exposure_twd", "weight_pct"],
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["sector", "actual_pct", "target_pct", "variance"],
          "additionalProperties": true
        }
      ]
    },
    "industryExposureItem": {
      "type": "object",
      "properties": {
        "市值": { "type": "number" },
        "權重": { "type": "string" }
      }
    },
    "page3": {
      "oneOf": [
        { "$ref": "#/$defs/page3_raw" },
        { "$ref": "#/$defs/page3_normalized" }
      ],
      "description": "page3｜保單接力引擎，支援 'current+summary' 原始結構或 normalized 對應鍵。"
    },
    "page3_raw": {
      "type": "object",
      "properties": {
        "system_target": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "目標配置比例。"
        },
        "current": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/allocationItem" },
          "description": "當前配置。"
        },
        "summary": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "allianz_combined": {
          "type": "object",
          "required": ["cost", "current_value", "roi", "monthly_dividend"],
          "additionalProperties": true,
          "properties": {
            "cost": { "type": "number" },
            "current_value": { "type": "number" },
            "cumulative_dividend": { "type": "number" },
            "roi": { "type": "string" },
            "monthly_dividend": { "type": ["number", "string"] }
          }
        },
        "first_gold": {
          "type": "object",
          "required": ["cost", "current_value", "roi", "monthly_dividend"],
          "additionalProperties": true,
          "properties": {
            "cost": { "type": "number" },
            "current_value": { "type": "number" },
            "cumulative_dividend": { "type": "number" },
            "roi": { "type": "string" },
            "monthly_dividend": { "type": ["number", "string"] }
          }
        },
        "total_monthly_dividend": {
          "type": "number",
          "description": "allianz + first_gold 本月配息合計。"
        },
        "relay_tracking": {
          "oneOf": [
            { "type": "object" },
            { "$ref": "#/$defs/relayTrackingArray" }
          ]
        },
        "relay_progress": {
          "$ref": "#/$defs/relayTrackingArray"
        },
        "july_dividend_calendar": {
          "type": "object",
          "additionalProperties": { "type": "object" }
        },
        "completed_operations": {
          "type": "array",
          "items": { "$ref": "#/$defs/completedOpRecord" }
        },
        "rebalancing": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "page3_normalized": {
      "type": "object",
      "description": "dashboard.py 會回退補充：current -> current_value/total_premium 等。",
      "properties": {
        "current": {
          "type": "object",
          "additionalProperties": true
        },
        "summary": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "total_monthly_dividend": { "type": "number" },
        "relay_progress": { "$ref": "#/$defs/relayTrackingArray" },
        "july_dividend_calendar": {
          "type": "object",
          "additionalProperties": { "type": "object" }
        },
        "completed_operations": {
          "type": "array",
          "items": { "$ref": "#/$defs/completedOpRecord" }
        },
        "rebalancing": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "relayTrackingStation": {
      "type": "object",
      "required": ["station", "date"],
      "additionalProperties": true,
      "properties": {
        "station": { "type": "string" },
        "date": { "type": "string" },
        "name": { "type": "string" },
        "convert_to": { "type": "string" },
        "status": { "type": "string" },
        "deadline": { "type": "string" },
        "ex_date": { "type": "string" },
        "schedule": { "type": "string" },
        "action": { "type": "string" }
      }
    },
    "relayTrackingArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/relayTrackingStation" }
    },
    "completedOpRecord": {
      "type": "object",
      "required": ["date", "policy", "操作", "轉出", "轉入", "狀態"],
      "additionalProperties": true
    },
    "page4": {
      "oneOf": [
        { "$ref": "#/$defs/page4_topLevel" },
        { "$ref": "#/$defs/page4_wrapped" }
      ],
      "description": "page4｜流動性調度站：可放頂層 page4_liquidity 或在 pages 包裝中。"
    },
    "page4_topLevel": {
      "type": "object",
      "required": ["banks", "liquidity"],
      "properties": {
        "banks": {
          "$ref": "#/$defs/bankACList"
        },
        "insurance": {
          "type": "array",
          "items": { "$ref": "#/$defs/insuranceRecord" }
        },
        "liquidity": {
          "$ref": "#/$defs/liquidityMetrics"
        },
        "upcoming_outflows": {
          "type": "array",
          "items": { "$ref": "#/$defs/payableRecord" }
        },
        "inflows": {
          "type": "array",
          "items": { "$ref": "#/$defs/cashFlowRecord" }
        },
        "payables": {
          "type": "array",
          "items": { "$ref": "#/$defs/payableRecord" }
        },
        "refill_alert": {
          "oneOf": [
            { "type": "object" },
            { "type": "null" }
          ]
        },
        "rental_tracker": {
          "type": "array",
          "items": { "$ref": "#/$defs/rentalTrackerRecord" }
        }
      }
    },
    "page4_wrapped": {
      "type": "object",
      "properties": {
        "page4_liquidity_banking": { "$ref": "#/$defs/page4_topLevel" },
        "page4_liquidity": { "$ref": "#/$defs/page4_topLevel" }
      }
    },
    "bankAC": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "bank": { "type": "string" },
        "account": { "type": "string" },
        "balance": { "type": "number" },
        "type": { "type": "string" },
        "水位": { "type": "string" },
        "狀態": { "type": "string" },
        "function": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "bankACList": {
      "type": "array",
      "items": { "$ref": "#/$defs/bankAC" }
    },
    "insuranceRecord": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "balance": { "type": "number" }
      }
    },
    "liquidityMetrics": {
      "type": "object",
      "required": ["runway_months", "three_month_buffer_twd", "buffer_coverage_x"],
      "properties": {
        "runway_months": {
          "oneOf": [
            { "type": "number" },
            { "type": "string" }
          ]
        },
        "three_month_buffer_twd": { "type": "number" },
        "buffer_coverage_x": { "type": "number" }
      }
    },
    "payableRecord": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "date": { "type": "string" },
        "name": { "type": "string" },
        "item": { "type": "string" },
        "amount": { "type": "number" },
        "priority": { "type": "string" },
        "days_left": { "type": "number" }
      }
    },
    "cashFlowRecord": {
      "type": "object",
      "required": ["item", "amount"],
      "additionalProperties": true,
      "properties": {
        "item": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "rentalTrackerRecord": {
      "type": "object",
      "required": ["name", "amount"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "days_left": { "type": "number" }
      }
    },
    "p0Task": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string" },
        "text": { "type": "string" },
        "item": { "type": "string" },
        "deadline": { "type": "string" },
        "priority": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "lifestyleEvent": {
      "type": "object",
      "required": ["date", "item"],
      "additionalProperties": true,
      "properties": {
        "date": { "type": "string" },
        "item": { "type": "string" },
        "days_left": { "type": "number" }
      }
    },
    "paymentScheduleRecord": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "cycle": { "type": "string" },
        "item": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" }
      }
    },
    "page5": {
      "type": "object",
      "properties": {
        "p0": {
          "type": "array",
          "items": { "$ref": "#/$defs/p0Task" }
        },
        "p0_tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/p0Task" },
          "description": "別名， dashboard.py 統一以 p0_tasks 使用。"
        },
        "p1": {
          "type": "array",
          "items": { "$ref": "#/$defs/p0Task" }
        },
        "p2": {
          "type": "array",
          "items": { "$ref": "#/$defs/p0Task" }
        },
        "paused": {
          "type": "array",
          "items": { "$ref": "#/$defs/p0Task" }
        },
        "lifestyle": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifestyleEvent" }
        },
        "payment_schedule": {
          "type": "array",
          "items": { "$ref": "#/$defs/paymentScheduleRecord" }
        },
        "report": { "type": "string" },
        "notion_nav": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "format": "uri"
          }
        }
      }
    }
  },
  "compatibility": {
    "load_roots": [
      { "path": "snapshot.pages", "acceptIf": "outer JSON has 'snapshot' key" },
      { "path": "pages", "acceptIf": "outer JSON has 'pages' key" },
      { "path": "page1/page2/page4/page5 legacy top-level keys", "acceptIf": "fallback layout" }
    ],
    "page2_aliases": {
      "source_keys": [
        "page2_strategic_risk",
        "page2_allocation"
      ],
      "field_aliases": {
